# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y0 [get_cells fpga_clk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y1 [get_cells U_emif_con/cs_or_wr_lo_BUFG_inst]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X1Y28 [get_ports fpga_clk]

# Clock net "fpga_clk_IBUF_BUFG" driven by instance "fpga_clk_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_fpga_clk_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_fpga_clk_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="fpga_clk_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_fpga_clk_IBUF_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0}
#endgroup

# Clock net "U_emif_con/cs_or_wr_lo_BUFG" driven by instance "U_emif_con/cs_or_wr_lo_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_U_emif_con/cs_or_wr_lo_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_U_emif_con/cs_or_wr_lo_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="U_emif_con/cs_or_wr_lo_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_U_emif_con/cs_or_wr_lo_BUFG}] -add {CLOCKREGION_X1Y0:CLOCKREGION_X1Y0}
#endgroup
